# Variáveis de Ambiente — Sistema PAR
# Copie este arquivo para .env e preencha os valores

# ──────────────────────────────────────
# SERVIDOR
# ──────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────
# AUTENTICAÇÃO JWT
# ──────────────────────────────────────
JWT_SECRET=sua_chave_secreta_jwt_muito_segura_aqui_mude_isso
JWT_EXPIRES_IN=8h

# ──────────────────────────────────────
# GOOGLE SHEETS (banco de dados)
# ──────────────────────────────────────
# ID da planilha (está na URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit)
GOOGLE_SPREADSHEET_ID=seu_spreadsheet_id_aqui

# Credenciais da Service Account (Google Cloud Console)
# Opção 1: caminho para o arquivo JSON
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./credentials/google-service-account.json

# Opção 2: conteúdo JSON em base64 (para deploy em produção)
# GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=

# ──────────────────────────────────────
# CLICKUP API
# ──────────────────────────────────────
# Token pessoal da API do ClickUp (Configurações > Apps > API Token)
CLICKUP_API_TOKEN=pk_seu_token_clickup_aqui

# ID do Workspace/Team (visível na URL do ClickUp)
CLICKUP_TEAM_ID=seu_team_id_aqui

# IDs dos Spaces monitorados (separados por vírgula)
CLICKUP_SPACE_IDS=space_id_1,space_id_2

# URL base para webhooks (deve ser pública — use ngrok em desenvolvimento)
CLICKUP_WEBHOOK_BASE_URL=https://seu-dominio.com

# ──────────────────────────────────────
# CONFIGURAÇÕES PAR
# ──────────────────────────────────────
# % padrão de impostos
DEFAULT_IMPOSTOS_PERC=16.33

# % padrão de taxa administrativa
DEFAULT_TAXA_ADM_PERC=12

# % padrão de comissão
DEFAULT_COMISSAO_PERC=7.50

# Limite de terceirizados (aviso em %, bloqueio em %)
TETO_TERCEIROS_AVISO=15
TETO_TERCEIROS_BLOQUEIO=20

# Dias sem atualização para alerta de Daily Scrum
ALERTA_DIAS_SEM_ATUALIZACAO=2

# Dias em "A Planejar" para alerta de planejamento
ALERTA_DIAS_A_PLANEJAR=7

# Intervalo de sincronização com ClickUp (em minutos)
SYNC_INTERVAL_MINUTES=15
